# MCP Super-Server Environment Template
# Copy to .env and fill in values

# Server Configuration
NODE_ENV=development
PORT=3000

# Agent Configuration
AGENT_ID=dev-agent

# Tool Gate Configuration
# Options: permissive, read_only, write_approval
GATE_MODE=permissive
MAX_CALLS_PER_SESSION=100

# Security
# MCP_API_SECRET=your-secret-token-here
# MCP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MCP_RATE_LIMIT=200
MCP_MAX_BODY_SIZE=1048576

# Supabase Persistence (optional)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key